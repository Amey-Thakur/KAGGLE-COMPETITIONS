# KAGGLE-COMPETITIONS
# Exclusion patterns for local development and system-generated artifacts

# System files
[Tt]humbs.db
[Dd]esktop.ini
.DS_Store

# Environment and workspace configuration
.vscode/
.idea/
*.swp
*.swo
*~
.ipynb_checkpoints/

# Dependency and build directories
node_modules/
dist/
build/
.env
.npm
.eslintcache

# Temporary and log files
*.tmp
*.log
*.bak
*.sav
*.old

# Documentation and archive artifacts
*.zip
*.tar.gz
*.rar
*.7z

# Kaggle Development Artifacts (Keep local only)
build_notebook.py
**/build_notebook.py
